  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && npx tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "npm run build && concurrently \"npx tsc -w\" \"nodemon --exec ts-node src/index.ts\" \"npm run worker:mail\"",
    "worker:mail": "ts-node src/workers/mail.worker.ts",
    "seed": "ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "postprisma:generate": "shx cp -r node_modules/.prisma/client/index.d.ts ../real-estate/src/types/prismaTypes.d.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
